{
  "name": "eve-fleet-firewall-trainer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "data:update": "node --experimental-strip-types scripts/update-eve-data.ts"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "0.180.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.55.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.180.0",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.0",
    "vite": "8.0.13",
    "vitest": "3.2.4"
  }
}
